# =============================================================================
# SCAI ProspectOps — Environment Configuration
# Copy to .env and fill in values. NEVER commit .env to version control.
# =============================================================================

# ── Google Sheets ─────────────────────────────────────────────────────────────
# The spreadsheet ID from the URL: docs.google.com/spreadsheets/d/SPREADSHEET_ID
SPREADSHEET_ID=your_spreadsheet_id_here

# Local development: path to the service account JSON file
GOOGLE_SERVICE_ACCOUNT_JSON=credentials/google-service-account.json

# Cloud deployment (Railway/Render): paste the full service account JSON as a string
# Get from Google Cloud → IAM → Service Accounts → Keys → Add Key → JSON
# Minify the JSON to a single line before pasting
GOOGLE_SERVICE_ACCOUNT_JSON_CONTENT=

# ── LLM / AI ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
TAVILY_API_KEY=tvly-...
PERPLEXITY_API_KEY=pplx-...

# AWS Bedrock (Claude for AI Scout synthesis)
AWS_BEARER_TOKEN_BEDROCK=
AWS_BEDROCK_REGION=us-east-1

# ── LinkedIn (Unipile) ───────────────────────────────────────────────────────
# Get from dashboard.unipile.com → Access Tokens
UNIPILE_API_KEY=your_unipile_api_key_here
UNIPILE_DSN=api21.unipile.com:15157
# Get account ID from /api/v1/accounts
UNIPILE_ACCOUNT_ID=your_linkedin_account_id_here

# ── Email Validation ─────────────────────────────────────────────────────────
ZEROBOUNCE_API_KEY=your_zerobounce_api_key_here

# ── Automation (optional) ────────────────────────────────────────────────────
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/...
N8N_SUBMISSION_DELAY=60

# ── Pipeline Settings ─────────────────────────────────────────────────────────
CHECKPOINT_DB=checkpoints/pipeline.db
LOG_DIR=logs
LINKEDIN_DELAY=5
ZEROBOUNCE_CREDIT_WARNING=50

# ── Server ───────────────────────────────────────────────────────────────────
UI_HOST=0.0.0.0
UI_PORT=8080
# PORT is set automatically by Railway/Render — do not set manually

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Local: leave as * (allows all)
# Production: set to your Vercel URL, e.g. https://yourapp.vercel.app
ALLOWED_ORIGINS=*
