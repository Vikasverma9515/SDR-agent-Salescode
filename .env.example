# =============================================================================
# SCAI ProspectOps - Environment Configuration Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control
# =============================================================================

# --- LLM ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Google Sheets ---
GOOGLE_SERVICE_ACCOUNT_JSON=credentials/service-account.json
# The spreadsheet ID from the URL: docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
SPREADSHEET_ID=your_spreadsheet_id_here

# --- LinkedIn (Chrome CDP) ---
# Start Chrome with: google-chrome --remote-debugging-port=9222
# Make sure you are logged into LinkedIn before running the pipeline
CHROME_CDP_URL=http://localhost:9222

# --- Unipile (LinkedIn API) ---
# Get from dashboard.unipile.com → Access Tokens
UNIPILE_API_KEY=your_unipile_api_key_here
UNIPILE_DSN=api21.unipile.com:15157
# Get account ID from /api/v1/accounts (use a Sales Navigator account)
UNIPILE_ACCOUNT_ID=your_linkedin_account_id_here

# --- Search APIs ---
OPENAI_API_KEY=your_openai_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# --- Email Validation ---
ZEROBOUNCE_API_KEY=your_zerobounce_api_key_here

# --- n8n Webhook ---
N8N_WEBHOOK_URL=your_n8n_webhook_url_here
N8N_SUBMISSION_DELAY=60

# --- Pipeline Settings ---
CHECKPOINT_DB=checkpoints/pipeline.db
LOG_DIR=logs
LINKEDIN_DELAY=5
ZEROBOUNCE_CREDIT_WARNING=50

# --- UI Server ---
UI_HOST=0.0.0.0
UI_PORT=8080
